<!--required variables: page, pages -->
<nav>
    <ul class="pagination">
        <li class="page-item {% if page == 1 %}disabled{% endif %}">
            <a href="{{ path('app_fixture_index', parameters = {page: page-1}) }}" class="page-link">Previous</a>
        </li>
        {% for i in 1..pages %}
            <li class="page-item {% if page == i %}active{% endif %}">
                <a class="page-link" href="{{ path('app_fixture_index', parameters = {page: i}) }}">{{ i }}</a>
            </li>
        {% endfor %}
        <li class="page-item {% if page == pages %}disabled{% endif %}">
            <a class="page-link" href="{{ path('app_fixture_index', parameters = {page: page+1}) }}">Next</a>
        </li>
    </ul>
</nav>
